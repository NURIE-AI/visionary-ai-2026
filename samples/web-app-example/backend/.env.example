# Upstream Nurie / NEPP vault API: origin ONLY (scheme + host, no path).
# Do NOT set this to …/api/v1 — that suffix is added automatically. A wrong host/path often
# surfaces as upstream JSON {"detail":"Not Found"} on upload/chat.
NURIE_API_BASE=https://api.vault.nurie.ai

# Personal API key — sent upstream as X-Api-Key (server-side only).
# Same as PERSONAL_API_KEY in nurie_api_doc/curl_personal_api_key_verification.md
NURIE_API_KEY=

# Local `uvicorn main:app` loads this file via python-dotenv. Docker Compose also uses
# env_file: ./backend/.env when present.
