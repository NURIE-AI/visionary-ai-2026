# --- Recommended: call Nurie through this repo’s FastAPI (see backend/.env.example: NURIE_API_KEY) ---
# Browser talks to your backend only; the key stays on the server.
VITE_BACKEND_URL=http://localhost:8000
# During `npm run dev`, Vite proxies `/nurie` → this target (override if backend is not local).
# VITE_BACKEND_PROXY_TARGET=http://localhost:8000

# --- Optional: direct-from-browser mode (key visible in the bundle if you use VITE_NURIE_API_KEY) ---
# Personal API key — sent as `X-Api-Key` (same as PERSONAL_API_KEY in
# nurie_api_doc/curl_personal_api_key_verification.md section 4.4).
# Security: Vite inlines `VITE_*` into the client JS bundle.
VITE_NURIE_API_KEY=

# Optional: Nurie API origin when calling vault directly from the browser.
VITE_NURIE_API_BASE=

# When "Use Vite dev proxy" is on, `/api` is forwarded here (see vite.config.js).
# VITE_NURIE_PROXY_TARGET=https://api.vault.nurie.ai

# Docker image build (optional):
# docker build --build-arg VITE_NURIE_API_KEY=... --build-arg VITE_NURIE_API_BASE=... -f frontend/Dockerfile frontend
